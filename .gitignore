# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/
build/
dist/

# ---- OS ----
.DS_Store

# ---- Claude Code agent worktrees ----
.claude/

